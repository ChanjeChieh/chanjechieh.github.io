    <content type="html"><![CDATA[<blockquote><p>����ԣ�<br>��һ���������棬�����±� i&lt;j����� A[i]&gt;A[j]����� (i,j) �� A[i]&gt;A[j] ��һ�� <strong>�����</strong>��</p></blockquote><h3 id="һ��ð������"><a href="#һ��ð������" class="headerlink" title="һ��ð������"></a>һ��ð������</h3><ul><li>�������� N ��Ԫ�ؿ��� N ����С��ͬ�����ݣ��ӵ�һ��Ԫ�ؿ�ʼ ��ð�ݡ�������ǰһ��Ԫ�رȺ�һ��Ԫ�ش��ʱ�ͽ�������Ԫ�ص�λ�ã�������ÿ��ð�ݾͽ��������ݷ��� ����� ���ظ� N �Ρ�  </li><li>�����һ�� ��ð�ݡ� û�з�����Ҫ��������������Ԫ�أ�˵�������Ѿ�������ɣ���ֱ���˳���<figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br></pre></td><td class="code"><pre><span class="line">void Bubble_Sort(ElementType A[], int N) &#123;</span><br><span class="line">    for(int P &#x3D; N; P &gt;&#x3D; 0; P--) &#123;</span><br><span class="line">        int flag &#x3D; 0; &#x2F;&#x2F;������ʶ�����Ƿ��Ѿ��ź���</span><br><span class="line">        for(int i &#x3D; 0; i &lt; P; i++)&#123;</span><br><span class="line">            if(A[i] &gt; A[i-1])&#123;</span><br><span class="line">                Swap(A[i], A[i-1]);</span><br><span class="line">                flag &#x3D; 1;</span><br><span class="line">            &#125;</span><br><span class="line">        &#125;</span><br><span class="line">        if( !flag ) break; &#x2F;&#x2F;�����Ѿ�������ɿ�ֱ���˳�</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure><blockquote><p>��������O (N)<br>������O (N^2)<br>�ŵ㣺�򵥡��ȶ������Դ�������������</p></blockquote></li></ul><h3 id="������������"><a href="#������������" class="headerlink" title="������������"></a>������������</h3><ul><li>�� N ��Ԫ�ص����鿴�� N ���ƣ����������ĳ�������ʼ��ʱ������ֻ���±�Ϊ 0 �������� ���ơ���������ÿ�α����У��õ� ��ǰ�±��һ ���� ���ơ���Ȼ�����������Ѿ��е������ҵ����ʵ�λ�ò��룬�ظ�������̡�</li><li>�����е� ���ơ� ��������ʱ������������ɡ�<figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><span class="line">void Insertion_Sort(ElementType A[], int N) &#123;</span><br><span class="line">    for(int P &#x3D; 1; P &lt; N; i++)&#123; &#x2F;&#x2F;����������һ���±�Ϊ 0 �������� ���ơ�</span><br><span class="line">        int i, temp &#x3D; A[P];</span><br><span class="line">        for(i &#x3D; P; i &gt; 0 &amp;&amp; A[i-1] &gt; temp; i--&gt;)</span><br><span class="line">            A[i] &#x3D; A[i-1];</span><br><span class="line">        A[i] &#x3D; temp;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure><blockquote><p>��������O (N)<br>������O (N^2)<br>�ŵ㣺�򵥡��ȶ�</p></blockquote></li></ul><p>�����������㷨��Ȼ�򵥣�����ÿ�ν�������Ԫ��ֻ�ܵ���һ������ԣ�Ӱ�쵽��Ч�ʡ��ǣ����Ч�ʵ�һ���������취ʹÿ�ν���Ԫ��ʱ�ܵ������ <strong>�����</strong>�����Ծ����������ϣ������</p><h3 id="����ϣ������"><a href="#����ϣ������" class="headerlink" title="����ϣ������"></a>����ϣ������</h3><ul><li>ϣ������ͨ������ <strong>��������</strong> �Ľ��˲�������ÿ�ν���Ԫ��ֻ�ܵ���һ������Ե�ȱ�㣬<figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br></pre></td><td class="code"><pre><span class="line">void Shell_Sort(ElementType A[], int N) &#123;</span><br><span class="line">    for(int D &#x3D; N&#x2F;2; D &gt; 0; D &#x2F;&#x3D; 2) &#123;</span><br><span class="line">        for(int P &#x3D; D; P &lt; N; p ++) &#123;</span><br><span class="line">            int i, temp &#x3D; A[P];</span><br><span class="line">            for(i &#x3D; P; i &gt; D; i -&#x3D; D)</span><br><span class="line">                A[i] &#x3D; A[i-D];</span><br><span class="line">            A[i] &#x3D; temp;</span><br><span class="line">        &#125;</span><br><span class="line">    &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure></li></ul>]]></content>
    
